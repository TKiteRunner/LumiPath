# ─── 应用 ────────────────────────────────────────────────────
APP_ENV=development                        # development / staging / production
APP_SECRET_KEY=change-me-to-a-long-random-secret-32-chars
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
APP_MASTER_KEY=change-me-pgcrypto-master-key  # pgcrypto 加密主密钥

# ─── JWT ─────────────────────────────────────────────────────
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=7
JWT_ALGORITHM=HS256

# ─── PostgreSQL ───────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=lumipath
POSTGRES_USER=lumipath
POSTGRES_PASSWORD=lumipath_dev_password
DATABASE_URL=postgresql+asyncpg://lumipath:lumipath_dev_password@localhost:5432/lumipath
# 同步 URL 供 Celery worker 使用（psycopg2）
DATABASE_URL_SYNC=postgresql+psycopg2://lumipath:lumipath_dev_password@localhost:5432/lumipath

# ─── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# ─── Neo4j ───────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=lumipath_dev_password

# ─── RabbitMQ ────────────────────────────────────────────────
RABBITMQ_URL=amqp://guest:guest@localhost:5672//

# ─── LLM 兜底 Key（用户未配置时使用）─────────────────────────
FALLBACK_ANTHROPIC_API_KEY=
FALLBACK_OPENAI_API_KEY=
FALLBACK_DEEPSEEK_API_KEY=
FALLBACK_QWEN_API_KEY=
FALLBACK_GEMINI_API_KEY=
FALLBACK_DOUBAO_API_KEY=        # 豆包（火山引擎 ARK）
FALLBACK_KIMI_API_KEY=          # Kimi（Moonshot AI）
FALLBACK_MINIMAX_API_KEY=       # MiniMax
FALLBACK_ZHIPU_API_KEY=         # 智谱 AI（GLM）

# ─── Google OAuth ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# ─── Vault ───────────────────────────────────────────────────
VAULT_BASE_PATH=./vault
VAULT_GIT_AUTO_COMMIT=true
VAULT_GIT_COMMIT_DEBOUNCE_SEC=10

# ─── Celery ──────────────────────────────────────────────────
CELERY_BROKER_URL=amqp://guest:guest@localhost:5672//
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ─── MCP Server ──────────────────────────────────────────────
MCP_SERVER_HOST=0.0.0.0
MCP_SERVER_PORT=8765
